# Server
PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/techseekho

# Comma-separated allowed origins for browser clients
CORS_ORIGINS=http://localhost:3000

# Allow requests without Origin header (CLI/server-to-server). Use false in strict production setups.
CORS_ALLOW_NO_ORIGIN=true

# Body parser limit
JSON_LIMIT=100kb

# Reverse proxy support (set true only behind a trusted proxy/load balancer)
TRUST_PROXY=false

# Show stack traces in API error responses (should be false in production)
EXPOSE_ERROR_DETAILS=true

# Hugging Face hosted inference
HF_TOKEN=Fuck_YOU
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_PROVIDER=together
